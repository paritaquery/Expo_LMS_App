{
  "expo": {
    "name": "Expo_LMS_App",
    "slug": "expo-lms-app",
    "scheme": "mini-lms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paritaquery.minilms"
    },
    "android": {
      "package": "com.paritaquery.minilms",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "apiBaseUrl": "https://api.freeapi.app",
      "router": {},
      "eas": {
        "projectId": "64dcb568-5ec6-4399-b033-105239b80271"
      }
    },
    "owner": "parita_panchani"
  }
}
